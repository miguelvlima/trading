APP_NAME=Trading App Backend
ENV=dev
MODE=PAPER
DATABASE_URL=postgresql+psycopg://trading:trading@localhost:5432/trading
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
DEV_DEFAULT_USER_EMAIL=dev@tradingapp.dev
DEV_DEFAULT_USER_PASSWORD=DevPass123!
DEV_DEFAULT_USER_DISPLAY_NAME=Dev User
DEV_DEFAULT_USER_IS_ADMIN=true
# Real-time feed: "ibkr" (default, IB Gateway) or "yfinance" (REST/polling fallback)
REALTIME_FEED_PROVIDER=ibkr
REALTIME_FEED_SYMBOLS=AAPL,MSFT,NVDA
REALTIME_FEED_TIMEFRAME=1d
# Worker ingests every timeframe in this list each poll cycle (per symbol)
REALTIME_FEED_TIMEFRAMES=1m,5m,15m,30m,1h,4h,1d,1w
REALTIME_FEED_POLL_SECONDS=60
REALTIME_FEED_STALE_AFTER_SECONDS=180
REALTIME_FEED_MIN_REQUEST_INTERVAL_SECONDS=1.0
# Max simultaneous IBKR market-data lines (operator env: "API Max tickers=100").
# Followed symbol + each index in the strip share this budget.
REALTIME_MAX_MARKET_DATA_LINES=100
# IBKR provider (only used when REALTIME_FEED_PROVIDER=ibkr); paper, read-only
IBKR_GATEWAY_HOST=127.0.0.1
IBKR_GATEWAY_PORT=4002
IBKR_CLIENT_ID=7
# Live-stream market-data type: 1=live, 2=frozen, 3=delayed, 4=delayed-frozen.
# Paper accounts without live-data subscriptions should use 3 (delayed) so the
# WebSocket receives ticks instead of nothing.
IBKR_MARKET_DATA_TYPE=3
